#!/bin/bash
set -e

# Create system user if not exists
if ! id -u a2al >/dev/null 2>&1; then
    useradd -r -s /bin/false -M -d /opt/a2al a2al
fi

# Create data directory
mkdir -p /opt/a2al/data
chown -R a2al:a2al /opt/a2al/data

# SELinux: set context if semanage is available
if command -v semanage >/dev/null 2>&1 && command -v restorecon >/dev/null 2>&1; then
    semanage fcontext -a -t var_t '/opt/a2al/data(/.*)?' 2>/dev/null || true
    restorecon -Rv /opt/a2al/data >/dev/null 2>&1 || true
fi

# Save the installed binary as .old so the updater can roll back to it
# if an auto-update is applied and the new binary fails health checks.
if [ -f /opt/a2al/bin/a2ald ]; then
    cp -f /opt/a2al/bin/a2ald /opt/a2al/bin/a2ald.old
fi

systemctl daemon-reload
systemctl enable a2ald
systemctl restart a2ald

echo "a2ald started. Config: /opt/a2al/data/config.toml"
