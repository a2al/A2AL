<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>A2AL Daemon — persistent peer-to-peer networking daemon for AI agents.</Description>
  </RegistrationInfo>
  <Triggers>
    <!-- Start when the current user logs on. -->
    <LogonTrigger>
      <Enabled>true</Enabled>
    </LogonTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <!-- Runs as the logged-on user; no admin required. -->
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <!-- No time limit — run indefinitely. -->
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <!-- Restart up to 10 times with a 1-minute delay on failure. -->
    <RestartInterval>PT1M</RestartInterval>
    <RestartCount>10</RestartCount>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <!-- Adjust to the actual path of a2ald.exe if not in PATH. -->
      <Command>a2ald</Command>
    </Exec>
  </Actions>
</Task>
